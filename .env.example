# ---------------------------------------------------------------------------
# Ramp environment configuration. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.
# ---------------------------------------------------------------------------

# SQLite database file used by packages/shared getDb()
RAMP_DB_PATH=ramp.db

# Anthropic API key — used by the harness + fix loop (Claude Code agent)
ANTHROPIC_API_KEY=

# OpenAI API key — used by bench curate (gpt-4o-mini) and harness fallback
OPENAI_API_KEY=

# Optional: anthropic | openai (defaults to anthropic when ANTHROPIC_API_KEY is set, else openai)
RAMP_AUDIT_PROVIDER=openai
RAMP_AUDIT_MODEL=gpt-4o-mini

# Optional: html-live | source-code — score only tasks in that auditMode subset
# AUDIT_MODE=html-live

# GitHub token with `repo` scope — used by the control-plane to open fix PRs
GITHUB_TOKEN=

# Arize observability (agent audit / tracing). Optional for local dev.
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# Default target the dashboard / control-plane talk to
CONTROL_PLANE_PORT=8787
DASHBOARD_PORT=5173
# Optional dashboard override (defaults to /api proxy → control-plane)
VITE_CONTROL_PLANE_URL=
